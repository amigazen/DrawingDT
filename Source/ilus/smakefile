#  ilus.datatype build script (SAS/C smake)
#
#  Loadable BOOPSI subclass of drawing.datatype.  Parses IFF ILUS
#  (PageStream / ProVector structured illustration) files via
#  iffparse.library and feeds the display list to the superclass.
#
#  Artefacts:
#    ilus.datatype        - the class, stripped (install to SYS:Classes/Datatypes/)
#    ilus.datatype.debug  - the unstripped build with symbols
#    ILUS                 - IFF DTYP descriptor (install to DEVS:DataTypes/)
#    mkdesc               - build-time tool that emits the descriptor (not installed)
#
#  Compiler options live in the SCOPTIONS file in this directory (read
#  automatically by sc).

MODNAME           = ilus
VERSION           = 45

TARGET            = $(MODNAME).datatype
TARGET_DEBUG      = $(MODNAME).datatype.debug
DESC              = ILUS
MKDESC            = mkdesc

CC                = sc
ASM               = asm
LD                = slink
RM                = delete force quiet

LDFLAGS           = ADDSYM SC SD MAP $(MODNAME).map HLSXF PLAIN SWIDTH 16
LDFLAGS_STRIP     = ND

C_SOURCES         = classbase.c dispatch.c load.c coord.c
ASM_SOURCES       = classinit.asm endcode.asm

OBJECTS           = classinit.o classbase.o dispatch.o load.o coord.o \
                    endcode.o

STARTUP           =
LIBS              = LIB:debug.lib LIB:amiga.lib LIB:scm.lib LIB:sc.lib

# Build the class and its descriptor.
all:            $(TARGET) $(DESC)

# Final, stripped class (the installable artefact).
$(TARGET):      $(TARGET_DEBUG)
                $(LD) FROM $(TARGET_DEBUG) TO $(TARGET) $(LDFLAGS_STRIP)

# Unstripped build with symbols.
$(TARGET_DEBUG): $(OBJECTS) $(LIBS)
                $(LD) <with <
FROM $(STARTUP) $(OBJECTS) TO $(TARGET_DEBUG) LIB $(LIBS) $(LDFLAGS)
<

# IFF DTYP descriptor.  mkdesc is an ordinary C program (standard startup
# and sc.lib), so link it through the SC frontend (LINK); it then runs on
# the build host and writes the ILUS descriptor binary.
$(DESC):        $(MKDESC)
                $(MKDESC) $(DESC)

$(MKDESC):      mkdesc.o
                $(CC) mkdesc.o LINK NOICONS TO $(MKDESC)

.c.o:
        $(CC) $*.c

.asm.o:
        $(ASM) $*.asm

# Dependencies
classinit.o:    classinit.asm $(MODNAME)_rev.rev classbase.i
endcode.o:      endcode.asm

classbase.o:    classbase.c classbase.h ilusclass.h
dispatch.o:     dispatch.c   classbase.h class_iprotos.h
load.o:         load.c       classbase.h class_iprotos.h ilusclass.h
coord.o:        coord.c      classbase.h
mkdesc.o:       mkdesc.c     $(MODNAME)_rev.h

version:
        @BumpRev $(VERSION) $(MODNAME)_rev

clean:
        -$(RM) \#?.o \#?.bak \#?.lnk
        -$(RM) $(TARGET) $(TARGET_DEBUG) $(MODNAME).map
        -$(RM) $(MKDESC) $(DESC)

install:        $(TARGET) $(DESC)
        copy $(TARGET) SYS:classes/datatypes/$(MODNAME).datatype
        copy $(DESC) DEVS:DataTypes/$(DESC)
        # copy ilusclass.h INCLUDE:datatypes
        avail flush >nil:

headers:
        copy ilusclass.h //SDK/Include_h/datatypes/ilusclass.h
